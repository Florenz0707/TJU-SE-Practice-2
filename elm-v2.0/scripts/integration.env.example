# Copy this file to elm-v2.0/scripts/.env and fill secrets locally.

# MySQL connection (sensitive)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=pass@WORD

# Database names for each service
DB_MAIN=elm
DB_POINTS=elm_points
DB_ACCOUNT=elm_account
DB_CATALOG=elm_catalog
DB_ORDER=elm_order

# Service base URLs
GATEWAY_URL=http://localhost:8080/elm
POINTS_SERVICE_URL=http://localhost:8081/elm
ACCOUNT_SERVICE_URL=http://localhost:8082/elm
CATALOG_SERVICE_URL=http://localhost:8083/elm
ORDER_SERVICE_URL=http://localhost:8084/elm
# Fallback URL for rollback script when ACCOUNT_SERVICE_URL_PREVIOUS is empty.
# Prefer using a healthy account-service endpoint instead of monolith default.
ACCOUNT_SERVICE_ROLLBACK_URL=http://localhost:8082/elm

# Internal token shared among services (sensitive)
INTERNAL_SERVICE_TOKEN=CHANGE_ME_INTERNAL_SERVICE_TOKEN_32CHARS_MIN

# Smoke runtime options
SMOKE_WALLET_BALANCE=500.00
KEEP_SERVICES_RUNNING=false

# Phase3 account drill options
PHASE3_DRILL_USER_ID=1
PHASE3_DRILL_AMOUNT=3.00

# Account gray switch options
ACCOUNT_GRAY_MODE=canary
ACCOUNT_SERVICE_URL_PREVIOUS=

# Optional override: start commands
# POINTS_START_CMD=mvn spring-boot:run
# ACCOUNT_START_CMD=mvn spring-boot:run
# CATALOG_START_CMD=mvn spring-boot:run
# ORDER_START_CMD=mvn spring-boot:run
# GATEWAY_START_CMD=mvn spring-boot:run

# Optional override: ports
# POINTS_PORT=8081
# ACCOUNT_PORT=8082
# CATALOG_PORT=8083
# ORDER_PORT=8084
# GATEWAY_PORT=8080
